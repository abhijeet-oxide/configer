# Backend-specific environment variables
# These override the root .env file

CONFIGER_REPO=../sample-repo
CONFIGER_ADDR=:8080
CONFIGER_ENV=development
CONFIGER_VERSION=0.1.0
CONFIGER_LOG_LEVEL=info
CONFIGER_SYNC_SECONDS=30
GIT_USER_NAME=Configer Bot
GIT_USER_EMAIL=bot@configer.local
FEATURE_SWAGGER_DOCS=true
