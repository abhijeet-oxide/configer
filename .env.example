# Backend Configuration
CONFIGER_REPO=./sample-repo
CONFIGER_ADDR=:8080
CONFIGER_ENV=development
CONFIGER_VERSION=0.1.0
CONFIGER_LOG_LEVEL=info
CONFIGER_SYNC_SECONDS=30

# Feature Flags
FEATURE_SWAGGER_DOCS=true
FEATURE_OFFLINE_MODE=true
FEATURE_AI_MODULE=false
FEATURE_RBAC=false
FEATURE_SSO=false

# Frontend Configuration
VITE_API_URL=http://localhost:8080
VITE_APP_NAME=Configer
VITE_APP_VERSION=0.1.0

# Database (optional, for future Postgres integration)
DATABASE_URL=postgres://configer:configer@localhost:5432/configer

# Git Configuration
GIT_USER_NAME=Configer Bot
GIT_USER_EMAIL=bot@configer.local

# GitHub Integration (optional)
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
