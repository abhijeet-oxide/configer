# Frontend build-time environment variables (Vite's VITE_ prefix bakes them in).
#
# By default the SPA calls the API at the same origin under /api, which the dev
# server and the production nginx both proxy to the backend. You only need to
# set this when the API lives on a different origin than the UI.
# VITE_API_BASE_URL=https://configer.example.com/api
#
# For rebuild-free repointing in production, serve a public/config.js that sets
# window.__CONFIGER__ = { apiBaseUrl: "..." }; it takes precedence over the
# baked-in value above (see frontend/src/api.ts).
