# Configer configuration. Copy to `.env` and adjust. Nothing here is secret by
# default; keep real tokens out of version control (.env is gitignored).
#
# Backend variables are read by internal/config (see backend/internal/config).
# Frontend variables must be prefixed VITE_ to reach the browser build.

# ------------------------------------------------------------------ backend
# HTTP listen address.
CONFIGER_ADDR=:8080
# Bootstrap repository served out of the box (path or git URL).
CONFIGER_REPO=./sample-repo
# Server-side state (workspace registry + clones of connected repos).
CONFIGER_DATA=./configer-data

# Deployment identity, surfaced in the UI and in commit attribution.
CONFIGER_VERSION=dev
CONFIGER_ENV=development           # development | staging | production
CONFIGER_GIT_NAME=Configer Bot
CONFIGER_GIT_EMAIL=configer-bot@localhost

# How often (seconds) to fetch origin and fast-forward the working tree.
CONFIGER_SYNC_SECONDS=30

# GitHub token used server-side to open/merge pull requests. Never sent to the
# browser. Leave empty for local/offline use.
GITHUB_TOKEN=

# --------------------------------------------------------------- platform
# Platform database (users, sessions, roles, audit). Leave DATABASE_URL empty
# for the default: an embedded SQLite file under CONFIGER_DATA — zero external
# services. Set a Postgres URL for production deployments.
# DATABASE_URL=postgres://configer:configer@localhost:5432/configer

# GitHub OAuth login (multi-user deployments). Create an OAuth app whose
# callback URL is <public-url>/api/auth/callback and fill these in; leave
# empty for single-user mode (no login surface at all).
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Public callback URL, needed when the deployment sits behind a proxy.
# CONFIGER_OAUTH_CALLBACK=https://configer.example.com/api/auth/callback
# For GitHub Enterprise, point both at your instance:
# GITHUB_API_URL=https://github.example.com/api/v3
# GITHUB_WEB_URL=https://github.example.com

# Deployment admins (comma-separated GitHub logins): may assign per-app roles.
CONFIGER_ADMINS=
# Role users get where no explicit assignment exists: viewer | editor | approver.
CONFIGER_DEFAULT_ROLE=editor
# Allow one extra browser origin to call the API (rarely needed: the frontend
# is same-origin behind nginx, and the Vite dev server proxies /api).
# CONFIGER_CORS_ORIGIN=https://configer-ui.example.com

# Observability.
CONFIGER_LOG_LEVEL=info            # debug | info | warn | error
CONFIGER_LOG_FORMAT=text           # text (dev) | json (aggregators)

# Feature flags: any CONFIGER_FLAG_<NAME>=true becomes flag "<name>". Read them
# with cfg.Flags.Enabled("name"). Example:
# CONFIGER_FLAG_EXPERIMENTAL_UI=true

# ------------------------------------------------------------------ frontend
# Dev-server proxy target for /api (Vite). Point this at a remote backend to
# develop the UI against a shared environment.
VITE_API_PROXY_TARGET=http://localhost:8080

# Optional base URL the built SPA calls instead of the same-origin "/api".
# Usually left blank (nginx proxies /api). For a static deploy talking to a
# separate API host, set e.g. https://api.configer.example.com/api
# For changing this WITHOUT a rebuild, use runtime config: see
# frontend/public/config.js.example.
VITE_API_BASE_URL=
